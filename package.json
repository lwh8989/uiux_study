{
  "name": "uiux_study",
  "version": "1.0.0",
  "description": "UI/UX Study with EJS + PostCSS(SCSS syntax)",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"nodemon server.js\" \"npm run css:watch\"",
    "start": "node server.js",
    "css:build": "postcss src/styles/**/*.pcss --dir public/css --ext css",
    "css:watch": "postcss src/styles/**/*.pcss --dir public/css --ext css --watch",
    "lint:js": "eslint src/**/*.js server.js",
    "lint:css": "stylelint \"src/styles/**/*.pcss\"",
    "lint": "npm run lint:js && npm run lint:css",
    "format": "prettier --write \"src/**/*\" \"server.js\""
  },
  "dependencies": {
    "ejs": "^3.1.9",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.32",
    "postcss-cli": "^11.0.0",
    "postcss-scss": "^4.0.9",
    "postcss-nested": "^6.0.1",
    "postcss-preset-env": "^9.3.0",
    "cssnano": "^6.0.2",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "eslint-config-prettier": "^9.1.0",
    "stylelint": "^16.1.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "stylelint-config-prettier-scss": "^1.0.0"
  }
}
